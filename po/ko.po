"        // would the child be? Instead, bind to `n` for the\n"
"        // sequence of 1 ..= 12. Now the age can be reported.\n"
msgstr ""
"// `1 ..= 12`의 값을 한 번에 `match`할 수 있습니다.\n"
"        // 하지만 그 경우, 아이는 몇 살일까요?\n"
"        // `n`에 매치된 값을 바인딩하여 값을 사용할 수 있습니다.\n"

