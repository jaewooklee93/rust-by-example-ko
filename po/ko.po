msgstr "// 모듈을 통해 동일한 이름을 가진 항목들을 구분할 수 있습니다.\n"

#: src/mod/visibility.md:95
msgid ""
"// Public items, including those inside nested modules, can be\n"
"    // accessed from outside the parent module.\n"
msgstr ""
"// 공용 항목은, 중첩된 모듈 내의 항목이라도\n"
