msgstr "// 여기서 이 함수를 사용할 수 있고, 나중에 정의해도 됩니다.\n"

#: src/fn.md:19
msgid "// Function that returns a boolean value\n"
msgstr "// 부울 값을 반환하는 함수\n"

#: src/fn.md:22
msgid "// Corner case, early return\n"
msgstr "// 예외적인 인자를 받았을 경우, 일찍 종료합니다.\n"

