msgstr "`literal`은 리터럴 상수를 위한 것입니다."

#: src/macros/designators.md:58
msgid "`pat` (_pattern_)"
msgstr "`pat` (_패턴_)"

#: src/macros/designators.md:59
msgid "`path`"
msgstr "`path`"

#: src/macros/designators.md:60
