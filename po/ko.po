"    // TODO ^ Try uncommenting this line\n"
msgstr ""
"// 이 시점에는 힙 메모리가 해제되었기 때문에 다음 동작은\n"
"    // 해제된 메모리를 참조하는 결과를 초래하지만 컴파일러가 허용하지 않습니다.\n"
"    // 오류! 이전 오류와 같은 이유\n"
"    //println!(\"b contains: {}\", b);\n"
"    // TODO ^ 이 줄을 해제해 보세요.\n"

