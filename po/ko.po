msgstr "\"I'm writing \\x52\\x75\\x73\\x74!\""

#: src/std/str.md:78
msgid "\"What are you doing\\x3F (\\\\x3F means ?) {}\""
msgstr "\"What are you doing\\x3F (\\\\x3F means ?) {}\""

#: src/std/str.md:80
msgid "// ...or Unicode code points.\n"
msgstr "// ...또는 유니코드 코드 포인트.\n"

